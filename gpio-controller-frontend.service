[Unit]
Description=GPIO Controller Frontend Server
After=network.target

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/home/pi/gpio-controller/frontend
ExecStart=/usr/bin/python3 -m http.server 3000
Restart=always
RestartSec=10

# Security settings
NoNewPrivileges=true
PrivateTmp=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=gpio-controller-frontend

[Install]
WantedBy=multi-user.target
